# Copy this file to .env and fill in your keys. Never commit .env.
ANTHROPIC_API_KEY=sk-ant-...

# Required: signups are stored in Upstash Redis (free, no card needed).
# Create a database at https://upstash.com — the REST URL and token are
# on its dashboard. On Vercel, use the "Storage" tab instead to provision
# one and it fills these in for you automatically.
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Optional: without this, Signal only generates the email HTML (no send).
# Get a free key at https://resend.com — no credit card needed.
RESEND_API_KEY=re_...

# Optional: your own email. If set (and RESEND_API_KEY is set), you get a
# notification email every time someone signs up on the landing page.
OWNER_EMAIL=you@example.com

# Port for the local server (optional, defaults to 3002)
PORT=3002

# Optional: set to "true" to skip the Anthropic API entirely and return a
# canned result instead — lets you test signup -> run -> preview -> send
# without spending API credit. Set to "false" (or remove) for real runs.
MOCK_AGENT=false

# Optional but recommended on Vercel: any random string. Protects /api/cron
# so only Vercel's own scheduled trigger can call it (it sends this back as
# `Authorization: Bearer <value>` automatically once set). Without it,
# /api/cron runs for anyone who requests it.
CRON_SECRET=

# Required on Vercel for real (non-mock) runs: Vercel's free tier kills a
# function after 60s, which a real research+draft run can exceed. QStash
# splits the work into two shorter, queued requests instead of one long one.
# Same Upstash account as Redis above — enable QStash in its dashboard.
# QSTASH_URL matters if your instance is region-specific (e.g. EU) — the
# dashboard's own "Quickstart" .env snippet has the exact right values.
QSTASH_URL=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
